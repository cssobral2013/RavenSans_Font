featurePrefixes = (
{
code = "languagesystem DFLT dflt;
languagesystem latn dflt;
languagesystem latn AZE ;
languagesystem latn TRK ;
languagesystem latn CAT ;
languagesystem latn TAT ;
languagesystem latn CRT ;
languagesystem latn KAZ ;
";
tag = Languagesystems;
}
);
features = (
{
code = "  feature locl;
  feature numr;
  feature dnom;
  feature frac;
  feature ordn;
  feature case;
  feature zero;
  feature pnum;
  feature tnum;
  feature salt;
  feature ss01;
  feature ss02;
  feature ss03;
  feature ss04;";
tag = aalt;
},
{
code = " # Localized Forms
 script latn; # Latin
 language AZE  exclude_dflt; # Azeri
    sub i by i.loclTRK;
    sub i by i.loclTRK;
    sub i by i.loclTRK;
    sub i by i.loclTRK;
    sub i by i.loclTRK;
 language TRK  exclude_dflt; # Turkish
    sub i by i.loclTRK;
    sub i by i.loclTRK;
    sub i by i.loclTRK;
    sub i by i.loclTRK;
    sub i by i.loclTRK;
 language CAT  exclude_dflt; # Catalan
    sub l middot' l by periodcentered.loclCAT;
    sub L middot' L by periodcentered.loclCAT.case;
 language TAT  exclude_dflt; # Tatar
    sub i by i.loclTRK;
    sub i by i.loclTRK;
    sub i by i.loclTRK;
    sub i by i.loclTRK;
    sub i by i.loclTRK;
 language CRT  exclude_dflt; # Crimean Tatar
    sub i by i.loclTRK;
    sub i by i.loclTRK;
    sub i by i.loclTRK;
    sub i by i.loclTRK;
    sub i by i.loclTRK;
 language KAZ  exclude_dflt; # Kazakh
    sub i by i.loclTRK;
    sub i by i.loclTRK;
    sub i by i.loclTRK;
    sub i by i.loclTRK;
    sub i by i.loclTRK;";
tag = locl;
},
{
code = " # Numerators
 # DEFAULT
    sub @numr1 by @numr2;
 script latn; # Latin
    sub @numr1 by @numr2;
 language AZE ; # Azeri
 language TRK ; # Turkish
 language CAT ; # Catalan
 language TAT ; # Tatar
 language CRT ; # Crimean Tatar
 language KAZ ; # Kazakh";
tag = numr;
},
{
code = " # Denominators
 # DEFAULT
    sub @numr1 by @dnom1;
 script latn; # Latin
    sub @numr1 by @dnom1;
 language AZE ; # Azeri
 language TRK ; # Turkish
 language CAT ; # Catalan
 language TAT ; # Tatar
 language CRT ; # Crimean Tatar
 language KAZ ; # Kazakh";
tag = dnom;
},
{
code = " # Fractions
 # DEFAULT
lookup frac7 {
    sub slash by fraction;
} frac7;
lookup frac8 {
    sub @numr1 by @numr2;
} frac8;
lookup frac9 {
    sub fraction @numr2' by [zero.dnom one.dnom two.dnom three.dnom four.dnom five.dnom six.dnom seven.dnom eight.dnom nine.dnom];
    sub @dnom1 @numr2' by [zero.dnom one.dnom two.dnom three.dnom four.dnom five.dnom six.dnom seven.dnom eight.dnom nine.dnom];
} frac9;
 script latn; # Latin
lookup frac7;
lookup frac8;
lookup frac9;
 language AZE ; # Azeri
 language TRK ; # Turkish
 language CAT ; # Catalan
 language TAT ; # Tatar
 language CRT ; # Crimean Tatar
 language KAZ ; # Kazakh";
tag = frac;
},
{
code = " # Ordinals
 # DEFAULT
    sub @numr1 [A a]' by [ordfeminine ordfeminine];
    sub @numr1 [O o]' by [ordmasculine ordmasculine];
 script latn; # Latin
    sub @numr1 [A a]' by [ordfeminine ordfeminine];
    sub @numr1 [O o]' by [ordmasculine ordmasculine];
 language AZE ; # Azeri
 language TRK ; # Turkish
 language CAT ; # Catalan
 language TAT ; # Tatar
 language CRT ; # Crimean Tatar
 language KAZ ; # Kazakh";
tag = ordn;
},
{
code = " # Case-Sensitive Forms
 # DEFAULT
    sub periodcentered.loclCAT by periodcentered.loclCAT.case;
 script latn; # Latin
    sub periodcentered.loclCAT by periodcentered.loclCAT.case;
 language AZE ; # Azeri
 language TRK ; # Turkish
 language CAT ; # Catalan
 language TAT ; # Tatar
 language CRT ; # Crimean Tatar
 language KAZ ; # Kazakh";
tag = case;
},
{
code = " # Standard Ligatures
 # DEFAULT
lookupflag IgnoreMarks;
    sub X X I I space A v e n by X_X_I_I_space_A_v_e_n;
    sub f f i by f_f_i;
    sub f i by fi;
    sub f l by fl;
 script latn; # Latin
    sub X X I I space A v e n by X_X_I_I_space_A_v_e_n;
    sub f f i by f_f_i;
    sub f i by fi;
    sub f l by fl;
 language AZE ; # Azeri
 language TRK ; # Turkish
 language CAT ; # Catalan
 language TAT ; # Tatar
 language CRT ; # Crimean Tatar
 language KAZ ; # Kazakh";
tag = liga;
},
{
code = " # Slashed Zero
 # DEFAULT
    sub zero by zero.zero;
 script latn; # Latin
    sub zero by zero.zero;
 language AZE ; # Azeri
 language TRK ; # Turkish
 language CAT ; # Catalan
 language TAT ; # Tatar
 language CRT ; # Crimean Tatar
 language KAZ ; # Kazakh";
tag = zero;
},
{
code = " # Contextual Alternates
 # DEFAULT
    sub hyphen greater by arrowright;
    sub less hyphen by arrowleft;
 script latn; # Latin
    sub hyphen greater by arrowright;
    sub less hyphen by arrowleft;
 language AZE ; # Azeri
 language TRK ; # Turkish
 language CAT ; # Catalan
 language TAT ; # Tatar
 language CRT ; # Crimean Tatar
 language KAZ ; # Kazakh";
tag = calt;
},
{
code = " # Proportional Figures
 # DEFAULT
    sub @pnum1 by @numr1;
 script latn; # Latin
    sub @pnum1 by @numr1;
 language AZE ; # Azeri
 language TRK ; # Turkish
 language CAT ; # Catalan
 language TAT ; # Tatar
 language CRT ; # Crimean Tatar
 language KAZ ; # Kazakh";
tag = pnum;
},
{
code = " # Tabular Figures
 # DEFAULT
    sub @numr1 by @pnum1;
 script latn; # Latin
    sub @numr1 by @pnum1;
 language AZE ; # Azeri
 language TRK ; # Turkish
 language CAT ; # Catalan
 language TAT ; # Tatar
 language CRT ; # Crimean Tatar
 language KAZ ; # Kazakh";
tag = tnum;
},
{
code = " # Discretionary Ligatures
 # DEFAULT
lookupflag IgnoreMarks;
    sub X X I I space A v e n by X_X_I_I_space_A_v_e_n;
 script latn; # Latin
    sub X X I I space A v e n by X_X_I_I_space_A_v_e_n;
 language AZE ; # Azeri
 language TRK ; # Turkish
 language CAT ; # Catalan
 language TAT ; # Tatar
 language CRT ; # Crimean Tatar
 language KAZ ; # Kazakh";
tag = dlig;
},
{
code = " # Stylistic Alternates
 # DEFAULT
    sub @salt1 by @salt2;
 script latn; # Latin
    sub @salt1 by @salt2;
 language AZE ; # Azeri
 language TRK ; # Turkish
 language CAT ; # Catalan
 language TAT ; # Tatar
 language CRT ; # Crimean Tatar
 language KAZ ; # Kazakh";
tag = salt;
},
{
code = " # Stylistic Set 1
 # DEFAULT
    sub @salt1 by @salt2;
 script latn; # Latin
    sub @salt1 by @salt2;
 language AZE ; # Azeri
 language TRK ; # Turkish
 language CAT ; # Catalan
 language TAT ; # Tatar
 language CRT ; # Crimean Tatar
 language KAZ ; # Kazakh";
tag = ss01;
},
{
code = " # Stylistic Set 2
 # DEFAULT
    sub bullet by bullet.ss02;
 script latn; # Latin
    sub bullet by bullet.ss02;
 language AZE ; # Azeri
 language TRK ; # Turkish
 language CAT ; # Catalan
 language TAT ; # Tatar
 language CRT ; # Crimean Tatar
 language KAZ ; # Kazakh";
tag = ss02;
},
{
code = " # Stylistic Set 3
 # DEFAULT
    sub bullet by bullet.ss03;
 script latn; # Latin
    sub bullet by bullet.ss03;
 language AZE ; # Azeri
